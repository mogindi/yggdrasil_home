groups:
- name: NetworkInterfaces
  rules:
  - alert: NetworkInterfaceDown-vpn0
    expr: network_interface_vpn0_up == 0
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Interface vpn0 is down or missing

  - alert: NetworkInterfaceDown-ceph_public
    expr: network_interface_ceph_public_up == 0
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Interface ceph_public is down or missing

  - alert: NetworkInterfaceDown-openstack_mgmt
    expr: network_interface_openstack_mgmt_up == 0
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Interface openstack_mgmt is down or missing

  - alert: NetworkInterfaceDown-ceph_cluster
    expr: network_interface_ceph_cluster_up == 0
    for: 5m
    labels:
      severity: critical
    annotations:
      summary: Interface ceph_cluster is down or missing
